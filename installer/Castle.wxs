<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
        Name="Castle"
        Manufacturer="Castle"
        Version="$(Version)"
        UpgradeCode="$(UpgradeCode)"
        Scope="perMachine"
        Compressed="yes"
    >
    <MajorUpgrade
            DowngradeErrorMessage="A newer version of Castle is already installed."
        />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Castle">
        <Component Id="CastleExecutable" Guid="*">
          <File
                        Id="CastleExe"
                        Source="$(SourceExe)"
                        Name="Castle.exe"
                        KeyPath="yes"
                    >
            <Shortcut
                            Id="CastleStartMenuShortcut"
                            Directory="ProgramMenuFolder"
                            Name="Castle"
                            Description="Private notes and kanban workspace"
                            WorkingDirectory="INSTALLFOLDER"
                            Advertise="yes"
                        >
              <ShortcutProperty
                                Key="System.AppUserModel.ID"
                                Value="Castle.App"
                            />
            </Shortcut>
          </File>
        </Component>
        <Component Id="CastleMcpExecutable" Guid="*">
          <File
                        Id="CastleMcpExe"
                        Source="$(SourceMcpExe)"
                        Name="Castle-MCP.exe"
                        KeyPath="yes"
                    />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />

    <CustomAction
            Id="RegisterCastleMcp"
            FileRef="CastleExe"
            ExeCommand="--register-mcp"
            Execute="deferred"
            Impersonate="yes"
            Return="ignore"
        />

    <InstallExecuteSequence>
      <Custom
                Action="RegisterCastleMcp"
                After="InstallFiles"
                Condition="NOT REMOVE"
            />
    </InstallExecuteSequence>

    <Feature Id="MainFeature" Title="Castle" Level="1">
      <ComponentRef Id="CastleExecutable" />
      <ComponentRef Id="CastleMcpExecutable" />
    </Feature>
  </Package>
</Wix>
